+
+function telegram_parse_destination($destination) {
+	$destination = trim((string)$destination);
+	$result = array(
+		"chat_id" => $destination
+	);
+
+	/*
+	 * Support Telegram forum topics in the Chat ID field by accepting
+	 * <chat_id>-topic-<topic_id> and splitting it into chat_id and
+	 * message_thread_id for the Telegram Bot API. Numeric chat IDs for
+	 * channels and supergroups still use the regular Telegram -100 prefix
+	 * as part of the chat ID itself.
+	 */
+	if (preg_match('/^(.+)-topic-(\d+)$/', $destination, $matches)) {
+		$result['chat_id'] = $matches[1];
+		$result['message_thread_id'] = $matches[2];
+		return $result;
+	}
+
+	if (preg_match('/-topic-/', $destination)) {
+		return false;
+	}
 
+	return $result;
+}
